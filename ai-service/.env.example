# --- Runtime ---
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8001
LOG_LEVEL=INFO

# --- Security / networking ---
API_KEY=change-me
REQUEST_TIMEOUT=5

# --- Hand-landmark provider (MediaPipe) ---
MODEL_PATH=models/hand_landmarker.task
MAX_HANDS=1
DETECTION_CONFIDENCE=0.5
TRACKING_CONFIDENCE=0.5

# --- Classifier provider ---
# today: stub | rule_based   (future: ml | tensorflow | onnx | pytorch)
CLASSIFIER_DRIVER=rule_based
